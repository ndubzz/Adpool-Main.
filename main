let user = null;
let filterCat = 'All';
let activeCamp = null;

try { user = JSON.parse(localStorage.getItem('ap_user')); } catch(e) {}

// ════════════════════════════════════
//  NAVIGATION
// ════════════════════════════════════
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  const tabMap = { home:0, market:1, brands:2, hiw:3, dash:4 };
  const tabs = document.querySelectorAll('.nav-tab');
  if (tabMap[id] !== undefined && tabs[tabMap[id]]) tabs[tabMap[id]].classList.add('active');
  window.scrollTo(0, 0);
  if (id === 'market') renderMarket();
  if (id === 'dash') renderDash();
  if (id === 'home') { renderHome(); recalc(); }
  if (id === 'hiw') renderFAQ();
}

// ════════════════════════════════════
//  CAMPAIGN CARD
// ════════════════════════════════════
function pct(c) { return Math.min(100, Math.round((c.pooled / c.cap) * 100)); }
function fmtCur(n) {
  if (n >= 1e6) return '$' + (n/1e6).toFixed(1) + 'M';
  if (n >= 1000) return '$' + (n/1000).toFixed(1) + 'K';
  return '$' + n.toLocaleString();
}
function launchDate(days) {
  const d = new Date(); d.setDate(d.getDate() + days);
  return d.toLocaleDateString('en-US', {month:'short', day:'numeric'});
}

function campCard(c) {
  const p = pct(c);
  const urgency = c.days <= 3 ? `<span style="color:var(--red)">⚡ ${c.days}d left</span>` : `${c.days}d to launch`;
  return `
  <div class="card ${c.premium ? 'card-premium' : ''}" onclick="openFund('${c.id}')">
    <div class="card-header">
      <div class="brand-row">
        <div class="brand-ico" style="background:${c.bg}">${c.icon}</div>
        <div>
          <div class="brand-name">${c.brand}</div>
          <div class="brand-cat">${c.cat}</div>
        </div>
      </div>
      <div class="roi-pill">+${c.roi}%</div>
    </div>
    <div class="prog-wrap">
      <div class="prog-labels"><span>${fmtCur(c.pooled)} pooled</span><span>${p}%</span></div>
      <div class="prog-track"><div class="prog-fill" style="width:${p}%"></div></div>
    </div>
    <div class="card-meta">
      <div class="meta-col"><div class="meta-val">${c.dur}d</div><div class="meta-lbl">Duration</div></div>
      <div class="meta-col"><div class="meta-val">${fmtCur(c.cap)}</div><div class="meta-lbl">Pool Cap</div></div>
      <div class="meta-col"><div class="meta-val">${c.revShare}%</div><div class="meta-lbl">Rev Share</div></div>
    </div>
    <div class="launch-row"><div class="launch-dot"></div>Launches ${launchDate(c.days)} · ${urgency}</div>
    <button class="fund-btn" onclick="openFund('${c.id}');event.stopPropagation()">Fund This Campaign</button>
  </div>`;
}

// ════════════════════════════════════
//  HOME
// ════════════════════════════════════
function renderHome() {
  const el = document.getElementById('homeCampaigns');
  if (!el) return;
  el.innerHTML = CAMPAIGNS.slice(0,3).map(campCard).join('');
}

// ════════════════════════════════════
//  MARKETPLACE
// ════════════════════════════════════
function setFilter(cat, btn) {
  filterCat = cat;
  document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  renderMarket();
}

function renderMarket() {
  let list = [...CAMPAIGNS];
  if (filterCat !== 'All') list = list.filter(c => c.cat === filterCat);
  const q = (document.getElementById('mktSearch')?.value || '').toLowerCase();
  if (q) list = list.filter(c => c.brand.toLowerCase().includes(q) || c.cat.toLowerCase().includes(q));
  const sort = document.getElementById('mktSort')?.value || 'popular';
  if (sort === 'roi') list.sort((a,b) => b.roi - a.roi);
  else if (sort === 'closing') list.sort((a,b) => a.days - b.days);
  else if (sort === 'newest') list.sort((a,b) => b.days - a.days);
  else list.sort((a,b) => b.pooled - a.pooled);
  const el = document.getElementById('mktGrid');
  const cnt = document.getElementById('mktCount');
  if (cnt) cnt.textContent = list.length + ' campaigns';
  if (!el) return;
  if (!list.length) { el.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--text3);"><div style="font-size:36px;margin-bottom:12px;">🔍</div><div style="font-size:16px;font-weight:600;color:var(--text2);margin-bottom:6px;">No campaigns found</div><div>Try a different filter</div></div>`; return; }
  el.innerHTML = list.map(campCard).join('');
}

// ════════════════════════════════════
//  FUND MODAL
// ════════════════════════════════════
function openFund(id) {
  activeCamp = CAMPAIGNS.find(c => c.id === id);
  if (!activeCamp) return;
  const c = activeCamp;
  document.getElementById('fmTitle').textContent = 'Fund ' + c.brand;
  document.getElementById('fmSub').textContent = c.cat + ' · ' + c.platform + ' Campaign';
  document.getElementById('fmPreview').innerHTML = `
    <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
      <div style="width:36px;height:36px;border-radius:8px;background:${c.bg};display:flex;align-items:center;justify-content:center;font-size:18px;">${c.icon}</div>
      <div><div style="font-weight:600;font-size:14px;">${c.brand}</div><div style="font-family:var(--mono);font-size:10px;color:var(--text3);">Launches ${launchDate(c.days)}</div></div>
    </div>
    <div style="display:flex;gap:16px;flex-wrap:wrap;">
      <div><div style="font-family:var(--mono);font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:2px;">Proj. ROI</div><div style="color:var(--green);font-weight:600;font-family:var(--mono);">+${c.roi}%</div></div>
      <div><div style="font-family:var(--mono);font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:2px;">Rev Share</div><div style="font-weight:600;font-family:var(--mono);">${c.revShare}%</div></div>
      <div><div style="font-family:var(--mono);font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:2px;">Duration</div><div style="font-weight:600;font-family:var(--mono);">${c.dur}d</div></div>
      <div><div style="font-family:var(--mono);font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:2px;">Filled</div><div style="font-weight:600;font-family:var(--mono);">${pct(c)}%</div></div>
    </div>`;
  updateFund();
  openModal('fundModal');
}

function updateFund() {
  if (!activeCamp) return;
  const c = activeCamp;
  const amt = parseFloat(document.getElementById('fmAmt')?.value) || 0;
  const share = amt / c.cap;
  const estRev = c.spend * (1 + c.roi / 100);
  const profit = Math.max(0, estRev - c.spend);
  const pool25 = profit * 0.25;
  const payout = share * pool25;
  const roi = amt > 0 ? ((payout / amt) * 100).toFixed(1) : '0.0';
  const el = document.getElementById('fmBreak');
  if (el) el.innerHTML = `
    <div class="fbd-row"><span>Pool share</span><span style="font-family:var(--mono);">${(share*100).toFixed(2)}%</span></div>
    <div class="fbd-row"><span>Est. campaign revenue</span><span style="font-family:var(--mono);">${fmtCur(Math.round(estRev))}</span></div>
    <div class="fbd-row"><span>Consumer pool (25%)</span><span style="font-family:var(--mono);">${fmtCur(Math.round(pool25))}</span></div>
    <div class="fbd-row hl"><span>Est. payout</span><span>+${fmtCur(payout.toFixed(2))} (+${roi}%)</span></div>`;
}

function setAmt(n) {
  const el = document.getElementById('fmAmt');
  if (el) { el.value = n; updateFund(); }
}

function confirmFund() {
  if (!user) { closeModal('fundModal'); setTimeout(() => openModal('signupModal'), 150); return; }
  const amt = parseFloat(document.getElementById('fmAmt')?.value) || 0;
  if (amt < 10) { showToast('Minimum investment is $10', 'err'); return; }
  if (!activeCamp) return;
  user.portfolio = user.portfolio || [];
  if (!user.portfolio.includes(activeCamp.id)) user.portfolio.push(activeCamp.id);
  user.invested = (user.invested || 0) + amt;
  localStorage.setItem('ap_user', JSON.stringify(user));
  closeModal('fundModal');
  showToast(`$${amt} invested in ${activeCamp.brand}! 🚀`, 'ok');
}

// ════════════════════════════════════
//  CALCULATOR
// ════════════════════════════════════
function recalc() {
  const inv = parseFloat(document.getElementById('cInvest')?.value) || 0;
  const pool = parseFloat(document.getElementById('cPool')?.value) || 1;
  const rev = parseFloat(document.getElementById('cRevenue')?.value) || 0;
  const profit = Math.max(0, rev - pool);
  const pool25 = profit * 0.25;
  const share = inv / pool;
  const payout = share * pool25;
  const roi = inv > 0 ? ((payout/inv)*100).toFixed(1) : '0.0';
  const s = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
  s('cShare', (share*100).toFixed(2) + '%');
  s('cPool2', fmtCur(Math.round(pool25)));
  s('cPayout', '$' + payout.toFixed(2));
  s('cROI', (parseFloat(roi) >= 0 ? '+' : '') + roi + '%');
  const roiEl = document.getElementById('cROI');
  if (roiEl) roiEl.style.color = parseFloat(roi) >= 0 ? 'var(--green)' : 'var(--red)';
}

// ════════════════════════════════════
//  AUTH
// ════════════════════════════════════
function doLogin() {
  const em = document.getElementById('liEmail')?.value;
  const pw = document.getElementById('liPass')?.value;
  if (!em || !pw) { showToast('Fill in all fields', 'err'); return; }
  const firstName = em.split('@')[0].replace(/[^a-zA-Z]/g,'');
  const u = { email:em, firstName: firstName.charAt(0).toUpperCase()+firstName.slice(1), role:'investor', balance:1250, invested:850, earned:284.17, portfolio:['C1','C2','C3'] };
  localStorage.setItem('ap_user', JSON.stringify(u));
  user = u;
  closeModal('loginModal');
  updateNavAuth();
  showToast('Welcome back, ' + u.firstName + '!', 'ok');
  setTimeout(() => showPage('dash'), 600);
}

function doSignup() {
  const first = document.getElementById('suFirst')?.value;
  const last = document.getElementById('suLast')?.value;
  const em = document.getElementById('suEmail')?.value;
  const pw = document.getElementById('suPass')?.value;
  const role = document.getElementById('suRole')?.value;
  if (!first || !last || !em || !pw) { showToast('Fill in all fields', 'err'); return; }
  if (pw.length < 8) { showToast('Password must be 8+ characters', 'err'); return; }
  const u = { email:em, firstName:first, lastName:last, role, balance:0, invested:0, earned:0, portfolio:[] };
  localStorage.setItem('ap_user', JSON.stringify(u));
  user = u;
  closeModal('signupModal');
  updateNavAuth();
  showToast('Welcome to AdPool, ' + first + '! 🎉', 'ok');
  setTimeout(() => showPage(role === 'brand' ? 'brands' : 'market'), 800);
}

function handleLogout() {
  localStorage.removeItem('ap_user');
  user = null;
  updateNavAuth();
  showToast('Logged out', 'ok');
  showPage('home');
}

function updateNavAuth() {
  const nr = document.querySelector('.nav-right');
  if (!nr) return;
  if (user) {
    nr.innerHTML = `<span style="font-family:var(--mono);font-size:11px;color:var(--text3);">Hi, ${user.firstName}</span><button class="btn btn-blue" onclick="showPage('dash')">Dashboard</button><button class="btn btn-ghost" onclick="handleLogout()">Log Out</button>`;
  } else {
    nr.innerHTML = `<button class="btn btn-ghost" onclick="openModal('loginModal')">Log In</button><button class="btn btn-blue" onclick="openModal('signupModal')">Get Started</button>`;
  }
}

// ════════════════════════════════════
//  DASHBOARD
// ════════════════════════════════════
function renderDash() {
  const u = user || { firstName:'Guest', balance:0, invested:0, earned:0, portfolio:[] };
  const s = (id, v) => { const el = document.getElementById(id); if (el) el.textContent = v; };
  s('dashGreet', u.firstName || 'Investor');
  s('wBal', fmtCur(u.balance || 0));
  s('dBal', fmtCur(u.balance || 0));
  s('dInvested', fmtCur(u.invested || 0));
  s('dEarned', fmtCur(u.earned || 0));
  const portfolio = (u.portfolio?.length ? u.portfolio : ['C1','C2','C3']);
  s('dCamp', portfolio.length);
  s('sbActive', portfolio.length);

  const pCamps = CAMPAIGNS.filter(c => portfolio.includes(c.id));
  const rows = document.getElementById('portfolioRows');
  if (rows) {
    if (!pCamps.length) {
      rows.innerHTML = `<div style="text-align:center;padding:40px 20px;color:var(--text3);"><div style="font-size:30px;margin-bottom:10px;">📊</div><div style="font-weight:600;color:var(--text2);margin-bottom:6px;">No investments yet</div><div style="font-size:12px;">Browse campaigns to make your first investment</div></div>`;
    } else {
      rows.innerHTML = pCamps.map(c => `
        <div class="table-row">
          <div class="t-brand"><div class="t-ico" style="background:${c.bg}">${c.icon}</div><div><div class="t-bname">${c.brand}</div><div class="t-bcat">${c.cat}</div></div></div>
          <div class="t-val">$${(Math.random()*150+30).toFixed(0)}</div>
          <div class="t-val up">+${c.roi}%</div>
          <div class="t-val">${launchDate(c.days)}</div>
          <div><span class="badge badge-live">LIVE</span></div>
        </div>`).join('');
    }
  }

  const actEl = document.getElementById('activityRows');
  if (actEl) {
    const acts = [
      { type:'earn', ico:'💰', title:'Terra Apparel payout', time:'2 hrs ago', amt:'+$4.82' },
      { type:'invest', ico:'📈', title:'Funded Kira Beauty', time:'1 day ago', amt:'-$100.00' },
      { type:'earn', ico:'💰', title:'Flux Coffee payout', time:'2 days ago', amt:'+$2.31' },
      { type:'invest', ico:'📈', title:'Funded Terra Apparel', time:'5 days ago', amt:'-$50.00' },
      { type:'earn', ico:'💰', title:'Kira Beauty payout', time:'1 week ago', amt:'+$7.14' },
    ];
    actEl.innerHTML = acts.map(a => `
      <div class="activity-item">
        <div class="act-left"><div class="act-ico ${a.type}">${a.ico}</div><div><div class="act-title">${a.title}</div><div class="act-time">${a.time}</div></div></div>
        <div class="act-amt ${a.type}">${a.amt}</div>
      </div>`).join('');
  }
}

function showDashSection(sec, btn) {
  document.getElementById('dash-portfolio').style.display = sec === 'portfolio' ? 'block' : 'none';
  document.getElementById('dash-activity').style.display = sec === 'activity' ? 'block' : 'none';
  document.querySelectorAll('.sb-link').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
}

// ════════════════════════════════════
//  FAQ
// ════════════════════════════════════
function renderFAQ() {
  const el = document.getElementById('faqList');
  if (!el || el.innerHTML) return;
  el.innerHTML = FAQS.map((f,i) => `
    <div class="faq-item">
      <button class="faq-q" onclick="toggleFAQ(${i})">${f.q}<span class="faq-ico" id="fi${i}">+</span></button>
      <div class="faq-a" id="fa${i}">${f.a}</div>
    </div>`).join('');
}

function toggleFAQ(i) {
  const a = document.getElementById('fa'+i);
  const ico = document.getElementById('fi'+i);
  const open = a.style.display === 'block';
  a.style.display = open ? 'none' : 'block';
  ico.textContent = open ? '+' : '×';
  if (ico) ico.style.transform = open ? '' : 'rotate(45deg)';
}

// ════════════════════════════════════
//  BRAND FORM
// ════════════════════════════════════
function submitBrand() {
  const name = document.getElementById('bName')?.value;
  const spend = document.getElementById('bSpend')?.value;
  const launch = document.getElementById('bLaunch')?.value;
  const platform = document.getElementById('bPlatform')?.value;
  const rev = document.getElementById('bRevShare')?.value;
  if (!name || !spend || !launch || !platform || !rev) { showToast('Please fill in all required fields', 'err'); return; }
  showToast(`${name} campaign submitted! Under review within 24hrs.`, 'ok');
  ['bName','bWebsite','bDesc','bSpend','bRevShare'].forEach(id => { const el = document.getElementById(id); if (el) el.value = ''; });
}

// ════════════════════════════════════
//  WAITLIST
// ════════════════════════════════════
function joinWaitlist() {
  const em = document.getElementById('waitlistEmail')?.value;
  const msg = document.getElementById('waitlistMsg');
  if (!em || !em.includes('@')) { if (msg) { msg.textContent = 'Enter a valid email.'; msg.style.color = 'var(--red)'; } return; }
  if (msg) { msg.textContent = "✓ You're on the list. We'll be in touch."; msg.style.color = 'var(--green)'; }
  if (document.getElementById('waitlistEmail')) document.getElementById('waitlistEmail').value = '';
}

// ════════════════════════════════════
//  MODALS
// ════════════════════════════════════
function openModal(id) { document.getElementById(id).classList.add('open'); document.body.style.overflow = 'hidden'; }
function closeModal(id) { document.getElementById(id).classList.remove('open'); document.body.style.overflow = ''; }
function outsideClose(e, id) { if (e.target === document.getElementById(id)) closeModal(id); }
function switchModal(a, b) { closeModal(a); setTimeout(() => openModal(b), 120); }

// ════════════════════════════════════
//  TOAST
// ════════════════════════════════════
function showToast(msg, type='ok') {
  const t = document.getElementById('toast');
  if (!t) return;
  t.textContent = msg;
  t.className = 'toast show ' + type;
  clearTimeout(window._toastTimer);
  window._toastTimer = setTimeout(() => { t.className = 'toast'; }, 3200);
}

